# 存储模式：
# 1. SQLite 模式：DATABASE_URL=sqlite:///data/chat.db
# 2. PostgreSQL 模式：DATABASE_URL=postgresql://ai_chat:change-me@postgres:5432/ai_chat
DATABASE_URL=sqlite:///data/chat.db

# Docker / PostgreSQL 配置
APP_PORT=8000
POSTGRES_DB=ai_chat
POSTGRES_USER=ai_chat
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432

# 应用环境
ENV=development

# 认证与安全
SECRET_KEY=generate-a-long-random-string-here

# Bootstrap 管理员配置（仅首次初始化使用）
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin123

# Bootstrap 系统配置（仅首次初始化使用）
BOOTSTRAP_SYSTEM_API_KEY=
BOOTSTRAP_SYSTEM_API_BASE=https://api.openai.com/v1
BOOTSTRAP_SYSTEM_MODEL=gpt-4o

# 一次性初始化向导开关
SETUP_WIZARD_ENABLED=true
