# ─── Database Configuration ──────────────────────────────────────────────────
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://ai_chat:your_password@localhost:5432/ai_chat

# App Environment: set to 'production' to enable HTTPS-only secure cookies
ENV=development

# ─── Auth & Security ────────────────────────────────────────────────────────
# A random secret string for JWT signing
SECRET_KEY=generate-a-long-random-string-here

# ─── Bootstrap Admin Configuration ──────────────────────────────────────────
# These values are used only during the FIRST database initialization.
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin123

# ─── Bootstrap System Configuration ─────────────────────────────────────────
# These values seed the database only when system_config does not exist yet.
BOOTSTRAP_SYSTEM_API_KEY=sk-your-openai-compatible-key
BOOTSTRAP_SYSTEM_API_BASE=https://api.openai.com/v1
BOOTSTRAP_SYSTEM_MODEL=gpt-4o
