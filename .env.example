# Storage mode:
# 1. SQLite mode: DATABASE_URL=sqlite:///data/chat.db
# 2. PostgreSQL mode: DATABASE_URL=postgresql://ai_chat:change-me@postgres:5432/ai_chat
DATABASE_URL=sqlite:///data/chat.db

# Docker / PostgreSQL settings
APP_PORT=8000
POSTGRES_DB=ai_chat
POSTGRES_USER=ai_chat
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432

# App Environment
ENV=development

# Auth & Security
SECRET_KEY=generate-a-long-random-string-here

# Bootstrap admin configuration (first initialization only)
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin123

# Bootstrap system configuration (first initialization only)
BOOTSTRAP_SYSTEM_API_KEY=
BOOTSTRAP_SYSTEM_API_BASE=https://api.openai.com/v1
BOOTSTRAP_SYSTEM_MODEL=gpt-4o

# One-time setup wizard switch
SETUP_WIZARD_ENABLED=true
